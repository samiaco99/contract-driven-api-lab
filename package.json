{
  "name": "contract-driven-api-lab",
  "version": "1.1.0",
  "description": "Contract-driven Fastify API lab with TypeBox schemas, SQLite persistence, and QA-focused integration and contract tests.",
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest run",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "coverage": "c8 --all --include \"src/**/*.ts\" --exclude \"src/server.ts\" --exclude \"src/repositories/order.repository.ts\" --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 --reporter=text node --import tsx scripts/coverage-smoke.ts",
    "test:contract": "schemathesis run http://localhost:3000/docs/json --checks all --include-method GET --include-method POST --include-method PATCH --include-method DELETE --exclude-method TRACE --suppress-health-check filter_too_much",
    "openapi:export": "tsx scripts/export-openapi.ts"
  },
  "keywords": [],
  "author": "Portfolio Author",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.49",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "c8": "^11.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
